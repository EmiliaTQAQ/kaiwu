# Backend API base URL used by browser requests.
# Leave empty in local Vite development to use the /api dev proxy.
# Leave empty in same-origin production, then proxy /api and project asset paths to the backend.
# Local split-origin example: VITE_API_BASE_URL=http://localhost:5001
# Production split-origin example: VITE_API_BASE_URL=https://api.your-domain.example
# Never set this to http://<public-ip>:5001 for an HTTPS website; browsers block it as mixed content.
VITE_API_BASE_URL=
